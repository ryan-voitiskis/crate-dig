---
// Data Flow Diagram — enrichment & analysis pipeline
// Horizontal flow: Input Sources → Processing → Downstream Uses

// Layout constants
const w = 960;
const h = 520;

// Column x-positions (center of each column)
const col1 = 90;   // inputs
const col2 = 350;  // processing tools
const col3 = 620;  // output attributes
const col4 = 860;  // downstream uses

// Row positions
const audioY = 140;
const metaY = 380;

// Processing tool positions
const stratumY = 100;
const essentiaY = 220;
const discogsY = 340;
const beatportY = 440;

// Downstream positions
const classifyY = 210;
const setBuildY = 350;

// Box dimensions
const inputW = 140;
const inputH = 52;
const toolW = 130;
const toolH = 44;
const outputW = 180;
const outputH = 20; // per line, used for text layout
const downW = 160;
const downH = 52;

// Helper: rounded rect attributes
function box(x: number, y: number, w: number, h: number) {
  return { x: x - w / 2, y: y - h / 2, width: w, height: h, rx: 6 };
}

// Arrow path from (x1,y1) to (x2,y2) with a slight curve
function arrow(x1: number, y1: number, x2: number, y2: number) {
  const mx = (x1 + x2) / 2;
  return `M ${x1} ${y1} C ${mx} ${y1}, ${mx} ${y2}, ${x2} ${y2}`;
}

// Output groups positioned next to their processing tool
const stratumOutputs = ['BPM', 'Key', 'Rhythm Regularity'];
const essentiaOutputs = ['Danceability', 'Spectral Centroid', 'Loudness', 'Onset Rate', 'Dynamic Complexity'];
const discogsOutputs = ['Genre', 'Style', 'Label', 'Year', 'Catalog #'];
const beatportOutputs = ['Genre', 'Sub-genre', 'BPM', 'Key', 'Label'];

// Output box heights (dynamic based on item count)
function outputBoxH(items: string[]) { return 24 + items.length * 17; }

const stratumOutH = outputBoxH(stratumOutputs);
const essentiaOutH = outputBoxH(essentiaOutputs);
const discogsOutH = outputBoxH(discogsOutputs);
const beatportOutH = outputBoxH(beatportOutputs);

// Connection definitions: input → processing
const inputConnections = [
  { x1: col1 + inputW / 2, y1: audioY, x2: col2 - toolW / 2, y2: stratumY },
  { x1: col1 + inputW / 2, y1: audioY, x2: col2 - toolW / 2, y2: essentiaY },
  { x1: col1 + inputW / 2, y1: metaY, x2: col2 - toolW / 2, y2: discogsY },
  { x1: col1 + inputW / 2, y1: metaY, x2: col2 - toolW / 2, y2: beatportY },
];

// Processing → output
const procOutputConnections = [
  { x1: col2 + toolW / 2, y1: stratumY, x2: col3 - outputW / 2, y2: stratumY },
  { x1: col2 + toolW / 2, y1: essentiaY, x2: col3 - outputW / 2, y2: essentiaY },
  { x1: col2 + toolW / 2, y1: discogsY, x2: col3 - outputW / 2, y2: discogsY },
  { x1: col2 + toolW / 2, y1: beatportY, x2: col3 - outputW / 2, y2: beatportY },
];

// Output → downstream (all outputs feed into both downstream boxes)
const outputDownConnections = [
  { x1: col3 + outputW / 2, y1: stratumY, x2: col4 - downW / 2, y2: classifyY },
  { x1: col3 + outputW / 2, y1: stratumY, x2: col4 - downW / 2, y2: setBuildY },
  { x1: col3 + outputW / 2, y1: essentiaY, x2: col4 - downW / 2, y2: classifyY },
  { x1: col3 + outputW / 2, y1: essentiaY, x2: col4 - downW / 2, y2: setBuildY },
  { x1: col3 + outputW / 2, y1: discogsY, x2: col4 - downW / 2, y2: classifyY },
  { x1: col3 + outputW / 2, y1: discogsY, x2: col4 - downW / 2, y2: setBuildY },
  { x1: col3 + outputW / 2, y1: beatportY, x2: col4 - downW / 2, y2: classifyY },
  { x1: col3 + outputW / 2, y1: beatportY, x2: col4 - downW / 2, y2: setBuildY },
];
---

<figure class="data-flow-diagram">
  <svg viewBox={`0 0 ${w} ${h}`} xmlns="http://www.w3.org/2000/svg" role="img"
       aria-label="Data flow diagram showing how audio files and track metadata flow through analysis and enrichment tools into genre classification and set building">
    <defs>
      <marker id="df-arrow" viewBox="0 0 10 7" refX="9" refY="3.5"
              markerWidth="8" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 3.5 L 0 7 z" class="arrow-head" />
      </marker>
    </defs>

    <!-- Column headers -->
    <text x={col1} y={28} text-anchor="middle" class="col-header">Input Sources</text>
    <text x={col2} y={28} text-anchor="middle" class="col-header">Processing</text>
    <text x={col3} y={28} text-anchor="middle" class="col-header">Outputs</text>
    <text x={col4} y={28} text-anchor="middle" class="col-header">Downstream</text>

    <!-- Thin header underlines -->
    <line x1={col1 - 50} y1={38} x2={col1 + 50} y2={38} class="header-line" />
    <line x1={col2 - 50} y1={38} x2={col2 + 50} y2={38} class="header-line" />
    <line x1={col3 - 50} y1={38} x2={col3 + 50} y2={38} class="header-line" />
    <line x1={col4 - 50} y1={38} x2={col4 + 50} y2={38} class="header-line" />

    <!-- ─── Connections: input → processing ─── -->
    {inputConnections.map(c => (
      <path d={arrow(c.x1, c.y1, c.x2, c.y2)} class="connector" marker-end="url(#df-arrow)" />
    ))}

    <!-- ─── Connections: processing → output ─── -->
    {procOutputConnections.map(c => (
      <path d={arrow(c.x1, c.y1, c.x2, c.y2)} class="connector" marker-end="url(#df-arrow)" />
    ))}

    <!-- ─── Connections: output → downstream ─── -->
    {outputDownConnections.map(c => (
      <path d={arrow(c.x1, c.y1, c.x2, c.y2)} class="connector-light" marker-end="url(#df-arrow)" />
    ))}

    <!-- ═══ INPUT SOURCES ═══ -->
    <!-- Audio Files -->
    <rect {...box(col1, audioY, inputW, inputH)} class="box-input" />
    <text x={col1} y={audioY - 8} text-anchor="middle" class="box-label">Audio Files</text>
    <text x={col1} y={audioY + 10} text-anchor="middle" class="box-sublabel">track audio on disk</text>

    <!-- Track Metadata -->
    <rect {...box(col1, metaY, inputW, inputH)} class="box-input" />
    <text x={col1} y={metaY - 8} text-anchor="middle" class="box-label">Track Metadata</text>
    <text x={col1} y={metaY + 10} text-anchor="middle" class="box-sublabel">artist, title, album</text>

    <!-- ═══ PROCESSING TOOLS ═══ -->
    <!-- stratum-dsp -->
    <rect {...box(col2, stratumY, toolW, toolH)} class="box-tool" />
    <text x={col2} y={stratumY - 4} text-anchor="middle" class="tool-name">stratum-dsp</text>
    <text x={col2} y={stratumY + 12} text-anchor="middle" class="tool-note">compiled in, always available</text>

    <!-- Essentia -->
    <rect {...box(col2, essentiaY, toolW, toolH)} class="box-tool" />
    <text x={col2} y={essentiaY - 4} text-anchor="middle" class="tool-name">Essentia</text>
    <text x={col2} y={essentiaY + 12} text-anchor="middle" class="tool-note">optional Python subprocess</text>

    <!-- Discogs -->
    <rect {...box(col2, discogsY, toolW, toolH)} class="box-tool" />
    <text x={col2} y={discogsY - 4} text-anchor="middle" class="tool-name">Discogs</text>
    <text x={col2} y={discogsY + 12} text-anchor="middle" class="tool-note">via broker API</text>

    <!-- Beatport -->
    <rect {...box(col2, beatportY, toolW, toolH)} class="box-tool" />
    <text x={col2} y={beatportY - 4} text-anchor="middle" class="tool-name">Beatport</text>
    <text x={col2} y={beatportY + 12} text-anchor="middle" class="tool-note">HTML/JSON extraction</text>

    <!-- ═══ OUTPUT ATTRIBUTE GROUPS ═══ -->
    <!-- stratum-dsp outputs -->
    <rect {...box(col3, stratumY, outputW, stratumOutH)} class="box-output" />
    {stratumOutputs.map((item, i) => (
      <text x={col3} y={stratumY - stratumOutH / 2 + 18 + i * 17} text-anchor="middle" class="output-item">{item}</text>
    ))}

    <!-- Essentia outputs -->
    <rect {...box(col3, essentiaY, outputW, essentiaOutH)} class="box-output" />
    {essentiaOutputs.map((item, i) => (
      <text x={col3} y={essentiaY - essentiaOutH / 2 + 18 + i * 17} text-anchor="middle" class="output-item">{item}</text>
    ))}

    <!-- Discogs outputs -->
    <rect {...box(col3, discogsY, outputW, discogsOutH)} class="box-output" />
    {discogsOutputs.map((item, i) => (
      <text x={col3} y={discogsY - discogsOutH / 2 + 18 + i * 17} text-anchor="middle" class="output-item">{item}</text>
    ))}

    <!-- Beatport outputs -->
    <rect {...box(col3, beatportY, outputW, beatportOutH)} class="box-output" />
    {beatportOutputs.map((item, i) => (
      <text x={col3} y={beatportY - beatportOutH / 2 + 18 + i * 17} text-anchor="middle" class="output-item">{item}</text>
    ))}

    <!-- ═══ DOWNSTREAM USES ═══ -->
    <!-- Genre Classification -->
    <rect {...box(col4, classifyY, downW, downH)} class="box-downstream" />
    <text x={col4} y={classifyY - 8} text-anchor="middle" class="downstream-label">Genre Classification</text>
    <text x={col4} y={classifyY + 10} text-anchor="middle" class="downstream-tool">classify_tracks</text>

    <!-- Set Building -->
    <rect {...box(col4, setBuildY, downW, downH + 24)} class="box-downstream" />
    <text x={col4} y={setBuildY - 18} text-anchor="middle" class="downstream-label">Set Building</text>
    <text x={col4} y={setBuildY} text-anchor="middle" class="downstream-tool">build_set</text>
    <text x={col4} y={setBuildY + 16} text-anchor="middle" class="downstream-detail">harmonic compatibility,</text>
    <text x={col4} y={setBuildY + 30} text-anchor="middle" class="downstream-detail">BPM, energy, genre affinity</text>
  </svg>
</figure>

<style>
  .data-flow-diagram {
    max-width: 960px;
    margin: 2rem auto;
  }
  .data-flow-diagram svg {
    width: 100%;
    height: auto;
  }

  /* Column headers */
  .col-header {
    font-family: var(--__sl-font);
    font-size: 11px;
    font-weight: 600;
    fill: var(--sl-color-text);
    opacity: 0.55;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .header-line {
    stroke: var(--sl-color-gray-5);
    stroke-width: 1;
    opacity: 0.5;
  }

  /* Arrow marker */
  .arrow-head {
    fill: var(--sl-color-gray-3);
  }

  /* Connection lines */
  .connector {
    fill: none;
    stroke: var(--sl-color-gray-3);
    stroke-width: 1.5;
    opacity: 0.6;
  }
  .connector-light {
    fill: none;
    stroke: var(--sl-color-gray-4);
    stroke-width: 1;
    opacity: 0.4;
  }

  /* Input source boxes */
  .box-input {
    fill: var(--sl-color-gray-6);
    stroke: var(--sl-color-gray-4);
    stroke-width: 1;
  }
  .box-label {
    font-family: var(--__sl-font);
    font-size: 13px;
    font-weight: 600;
    fill: var(--sl-color-text);
  }
  .box-sublabel {
    font-family: var(--__sl-font);
    font-size: 9.5px;
    fill: var(--sl-color-text);
    opacity: 0.55;
  }

  /* Processing tool boxes */
  .box-tool {
    fill: color-mix(in srgb, var(--sl-color-accent) 12%, var(--sl-color-gray-6));
    stroke: var(--sl-color-accent);
    stroke-width: 1.2;
    opacity: 0.9;
  }
  .tool-name {
    font-family: var(--__sl-font-mono);
    font-size: 12px;
    font-weight: 600;
    fill: var(--sl-color-text);
  }
  .tool-note {
    font-family: var(--__sl-font);
    font-size: 8.5px;
    fill: var(--sl-color-text);
    opacity: 0.5;
  }

  /* Output attribute boxes */
  .box-output {
    fill: var(--sl-color-gray-6);
    stroke: var(--sl-color-gray-5);
    stroke-width: 0.8;
  }
  .output-item {
    font-family: var(--__sl-font);
    font-size: 10.5px;
    fill: var(--sl-color-text);
    opacity: 0.8;
  }

  /* Downstream use boxes */
  .box-downstream {
    fill: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-6));
    stroke: var(--sl-color-accent);
    stroke-width: 1.5;
  }
  .downstream-label {
    font-family: var(--__sl-font);
    font-size: 13px;
    font-weight: 600;
    fill: var(--sl-color-text);
  }
  .downstream-tool {
    font-family: var(--__sl-font-mono);
    font-size: 10.5px;
    fill: var(--sl-color-text-accent);
    opacity: 0.85;
  }
  .downstream-detail {
    font-family: var(--__sl-font);
    font-size: 8.5px;
    fill: var(--sl-color-text);
    opacity: 0.5;
  }
</style>

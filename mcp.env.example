# Copy to ~/.config/reklawdbox/mcp.env and edit values for your machine.

# Optional when using Rekordbox default path.
REKORDBOX_DB_PATH=/Users/<you>/Library/Pioneer/rekordbox/master.db

# Discogs broker. Run `reklawdbox setup` for guided configuration.
# The URL defaults to the hosted broker; only override for local development:
# REKLAWDBOX_DISCOGS_BROKER_URL=http://127.0.0.1:8787
# REKLAWDBOX_DISCOGS_BROKER_TOKEN=<your-token>

# Optional Essentia override.
CRATE_DIG_ESSENTIA_PYTHON=/Users/<you>/.local/share/reklawdbox/essentia-venv/bin/python
